# loom configuration — copy to ~/.config/loom/config and edit
# Lines starting with # are comments. Values may use ~ for $HOME.

# ── Vault ──────────────────────────────────────────────────────────────────
# Path to your markdown vault directory.
# This directory will be created by `loom init` if it doesn't exist.
LOOM_VAULT="~/vault"

# ── tmux ───────────────────────────────────────────────────────────────────
# Prefix for tmux session names. Sessions are named <prefix>-<task-slug>.
LOOM_SESSION_PREFIX="loom"

# ── Work root ───────────────────────────────────────────────────────────────
# Default working directory for new tasks. Shown as the first option in the
# directory picker when running `loom new` without --dir.
# Empty = use current directory as first option.
LOOM_WORK_ROOT="~/work/forklift"

# ── Default model ───────────────────────────────────────────────────────────
LOOM_DEFAULT_MODEL="claude-opus-4-6"

# ── Web UI ─────────────────────────────────────────────────────────────────
LOOM_WEB_PORT="7799"

# When using the gateway, bind to localhost only (the tunnel connects it externally).
# Without a gateway, use 0.0.0.0 for direct LAN access.
LOOM_WEB_BIND="127.0.0.1"

# ── Gateway (central AWS reverse-proxy) ────────────────────────────────────
# See gateway/setup-gateway.sh to set up the AWS instance.
# Run `loom tunnel enable` after setting these to install systemd services.
#
# LOOM_GATEWAY_HOST="loom.yourdomain.com"
# LOOM_GATEWAY_USER="loom-tunnel"
# LOOM_GATEWAY_PORT="17799"   # unique per machine: 17799, 17800, 17801, …

# Optional Bearer token for web UI auth. Empty = no auth (only do this on localhost).
# Access via: http://host:7799/?token=your-secret
# LOOM_WEB_TOKEN=""

# ── Distillation ───────────────────────────────────────────────────────────
# auto   = open distillation window on PreCompact and `loom done`
# manual = only on `loom done`
# off    = never
LOOM_DISTILL="auto"

# Claude model to use for distillation windows.
# (The model is selected when the interactive claude session starts.)
LOOM_DISTILL_MODEL="claude-sonnet-4-5"

# ── Notifications ──────────────────────────────────────────────────────────
# Comma-separated list of backends to enable: notify-send, ntfy, bell
LOOM_NOTIFICATIONS="notify-send"

# ntfy settings (used when 'ntfy' is in LOOM_NOTIFICATIONS)
# LOOM_NTFY_TOPIC="loom"
# LOOM_NTFY_SERVER="https://ntfy.sh"

# ── Skills ─────────────────────────────────────────────────────────────────
# Skills are symlinked from <loom>/skills/ to ~/.claude/skills/ by install.sh.
# No config needed; just re-run install.sh after adding a skill to the repo.
