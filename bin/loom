#!/usr/bin/env python3
"""loom — tmux-based Claude Code workbench."""

import argparse
import json
import os
import shutil
import subprocess
import sys
import uuid
from pathlib import Path

# Resolve lib path relative to this script
_BIN = Path(__file__).resolve().parent
_LIB = _BIN.parent / "lib"
sys.path.insert(0, str(_LIB))

from loom import (
    Config, VaultManager, StateManager, TmuxManager, NotifyManager,
    format_age, slugify, load_managers, find_loom_dir,
)

# ---------------------------------------------------------------------------
# Terminal colours (only when stdout is a TTY)
# ---------------------------------------------------------------------------

_IS_TTY = sys.stdout.isatty()

def _c(code: str, text: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _IS_TTY else text

def green(t):  return _c("92", t)
def yellow(t): return _c("93", t)
def gray(t):   return _c("90", t)
def red(t):    return _c("91", t)
def bold(t):   return _c("1",  t)
def dim(t):    return _c("2",  t)
def cyan(t):   return _c("96", t)

STATUS_DOT = {
    "working":          green("●"),
    "waiting":          yellow("◌"),
    "idle":             gray("○"),
    "starting":         cyan("◎"),
    "done":             dim("✓"),
    "dead":             red("✗"),
    "error":            red("✗"),
}

def _dot(status: str) -> str:
    return STATUS_DOT.get(status, gray("?"))

# ---------------------------------------------------------------------------
# Model picker
# ---------------------------------------------------------------------------

KNOWN_MODELS = [
    ("claude-opus-4-6",    "Opus 4.6  · 1M ctx"),
    ("claude-opus-4-8",    "Opus 4.8  · 1M ctx · latest"),
    ("claude-sonnet-5",    "Sonnet 5  · 1M ctx"),
    ("claude-sonnet-4-6",  "Sonnet 4.6· 1M ctx"),
    ("claude-haiku-4-5",   "Haiku 4.5 · 200K ctx · fastest"),
]

def pick_model(default: str) -> str:
    """Interactive model picker; falls back to default when non-interactive."""
    if not sys.stdin.isatty():
        return default
    print(f"\n{bold('Select model:')}")
    for i, (mid, desc) in enumerate(KNOWN_MODELS, 1):
        marker = dim(" ← default") if mid == default else ""
        print(f"  {i}. {mid:<28} {dim(desc)}{marker}")
    while True:
        try:
            raw = input(f"\n  Enter number [default: {default}]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return default
        if not raw:
            return default
        try:
            idx = int(raw) - 1
            if 0 <= idx < len(KNOWN_MODELS):
                return KNOWN_MODELS[idx][0]
        except ValueError:
            pass
        print(f"  Please enter 1–{len(KNOWN_MODELS)}")


def _die(msg: str, code: int = 1):
    print(red(f"error: {msg}"), file=sys.stderr)
    sys.exit(code)


def _confirm(prompt: str) -> bool:
    try:
        return input(f"{prompt} [y/N] ").strip().lower() == "y"
    except (EOFError, KeyboardInterrupt):
        return False


# ---------------------------------------------------------------------------
# Work-dir picker
# ---------------------------------------------------------------------------

def pick_work_dir(cfg: Config, vault: VaultManager) -> str:
    """Interactive directory picker using recent task roots + configured default."""
    # Build candidate list: configured root first, then recent unique cwds from vault
    home = str(Path.home())
    default = cfg.work_root or os.getcwd()

    # Collect up to 6 unique recent cwds from active tasks (most-recently-updated first)
    tasks = []
    if vault.is_initialized():
        tasks = sorted(
            vault.list_tasks(include_archived=False),
            key=lambda t: t.get("updated", t.get("started", "")),
            reverse=True,
        )
    seen: dict = {}
    for t in tasks:
        cwd = t.get("cwd", "")
        if cwd and cwd not in seen:
            seen[cwd] = True

    # Deduplicated options: default first, then recents, no duplicates
    options = [default]
    for cwd in seen:
        if cwd not in options:
            options.append(cwd)
    options = options[:7]  # cap at 7

    if not sys.stdin.isatty():
        return options[0]

    print(f"\n{bold('Select working directory:')}")
    for i, path in enumerate(options, 1):
        display = path.replace(home, "~")
        label = ""
        if i == 1 and cfg.work_root:
            label = dim("  ← default (LOOM_WORK_ROOT)")
        elif i == 1:
            label = dim("  ← current dir")
        elif i <= 2:
            label = dim("  recent")
        print(f"  {i}. {display}{label}")
    print(f"  Or type a path. Enter = {options[0].replace(home, '~')}: ", end="", flush=True)

    try:
        raw = input().strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return options[0]

    if not raw:
        return options[0]
    try:
        idx = int(raw) - 1
        if 0 <= idx < len(options):
            return options[idx]
    except ValueError:
        pass
    # Treat as a path
    return os.path.abspath(os.path.expanduser(raw))


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_init(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Initialize the vault."""
    if vault.is_initialized():
        print(f"Vault already initialized at {vault.vault}")
        return
    vault.init(git=not args.no_git)
    print(f"Initialized vault at {bold(str(vault.vault))}")
    print(f"  Run {bold('loom new <task>')} to start your first task.")


def cmd_new(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Create a new task and tmux session."""
    if not vault.is_initialized():
        _die("Vault not initialized. Run: loom init")

    slug = slugify(args.slug)
    if not slug:
        _die("Invalid task name.")

    # Working directory
    if args.dir:
        cwd = os.path.abspath(args.dir)
    else:
        cwd = pick_work_dir(cfg, vault)

    goal = args.goal or ""
    session_id = str(uuid.uuid4())
    session_name = tmux.session_name(slug)

    # Model selection
    if args.model:
        model = args.model
    else:
        model = pick_model(cfg.default_model)

    if tmux.session_exists(slug):
        _die(f"Session {session_name} already exists. Use: loom go {slug}")

    try:
        vault.create_task(slug, session_id, cwd, goal, model=model)
    except FileExistsError:
        _die(f"Task '{slug}' already exists in the vault.")

    state.upsert(slug, session_id=session_id, status="starting", cwd=cwd,
                 tmux_session=session_name, project=Path(cwd).name, model=model)

    if not tmux.new_session(slug, cwd, session_id, model=model):
        vault.task_path(slug).unlink(missing_ok=True)
        state.remove(slug)
        _die("Failed to create tmux session. Is tmux installed and running?")

    # Fire the goal as Claude's first prompt once the session is ready
    if goal:
        tmux.send_after_ready(slug, goal)
        print(f"{green('✓')} Created task {bold(slug)}")
        print(f"  Session : {session_name}")
        print(f"  Model   : {model}")
        print(f"  CWD     : {cwd}")
        print(f"  Goal    : {dim(goal[:80] + ('…' if len(goal) > 80 else ''))}")
        print(f"\n  Goal will be sent once Claude starts. Attach: {bold(f'loom go {slug}')}")
        print(dim("  Note: in a directory Claude hasn't seen before, a trust dialog appears —"))
        print(dim("  the goal is delivered automatically right after you accept it."))
    else:
        print(f"{green('✓')} Created task {bold(slug)}")
        print(f"  Session : {session_name}")
        print(f"  Model   : {model}")
        print(f"  CWD     : {cwd}")
        print(f"\n  Attach  : {bold(f'loom go {slug}')}")


def cmd_ls(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """List active tasks."""
    if not vault.is_initialized():
        print("No vault initialized. Run: loom init")
        return

    show_all = getattr(args, "all", False)
    plain    = getattr(args, "plain", False)
    tasks    = vault.list_tasks(include_archived=show_all)

    # By default hide done/archived tasks (they have _archived=True)
    if not show_all:
        tasks = [t for t in tasks if not t.get("_archived") and t.get("status") not in ("done",)]

    if not tasks:
        if not plain:
            msg = "No active tasks." if not show_all else "No tasks."
            print(dim(msg))
        return

    live_sessions = {s["slug"] for s in tmux.list_sessions()}

    col_task   = max((len(t.get("slug", "")) for t in tasks), default=4)
    col_task   = max(col_task, 4)
    col_status = 10
    col_proj   = max((len(t.get("project", "")) for t in tasks), default=7)
    col_proj   = max(col_proj, 7)

    if not plain:
        header = (
            f"  {'TASK':<{col_task}}  {'STATUS':<{col_status}}  {'PROJECT':<{col_proj}}  {'AGE':>5}  CWD"
        )
        print(bold(header))
        print(dim("  " + "─" * (len(header) - 2)))

    for t in tasks:
        slug     = t.get("slug", "")
        status   = t.get("status", "idle")
        project  = t.get("project", "")
        cwd      = t.get("cwd", "")
        updated  = t.get("updated", t.get("started", ""))
        age      = format_age(updated)
        is_alive = slug in live_sessions
        archived = t.get("_archived", False)

        # Any "live" status without a live tmux session means the session died.
        # Unmanaged (adopted) sessions have no tmux session of their own.
        unmanaged = t.get("unmanaged") in ("true", True)
        if status not in ("done",) and not is_alive and not archived and not unmanaged:
            display_status = "dead"
        elif archived:
            display_status = "done"
        else:
            display_status = status

        home = str(Path.home())
        cwd_display = cwd.replace(home, "~")
        if len(cwd_display) > 40:
            cwd_display = "…" + cwd_display[-39:]

        dot = _dot(display_status)

        if plain:
            print(f"{slug:<{col_task}}  {display_status:<{col_status - 2}}  {project:<{col_proj}}  {age:>5}  {cwd_display}")
        else:
            alive_marker = "  " if is_alive else dim(" ∅")
            status_col   = f"{display_status:<{col_status - 2}}"
            row = f"{alive_marker} {dot} {slug:<{col_task}}  {status_col}  {project:<{col_proj}}  {age:>5}  {dim(cwd_display)}"
            # Dim the whole row for done/archived tasks
            print(dim(row) if archived else row)

    if not plain:
        active = sum(1 for t in tasks if not t.get("_archived"))
        done   = sum(1 for t in tasks if t.get("_archived"))
        parts  = [f"  {active} active"]
        if done:
            parts.append(f"{done} done")
        parts.append("∅ = no live session")
        print()
        print(dim("  ·  ".join(parts)))


def cmd_popup(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Open an fzf session picker in a tmux popup."""
    loom_bin = str(Path(__file__).resolve())
    try:
        tmux.popup(loom_bin)
    except FileNotFoundError as e:
        _die(str(e))
    except RuntimeError as e:
        _die(str(e))


def cmd_go(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Attach to a task's tmux session, resuming it automatically if not running."""
    slug = args.slug

    if not tmux.session_exists(slug):
        task = vault.get_task(slug)
        if not task:
            _die(f"No task '{slug}' found. Run: loom ls --all")

        session_id = task.get("session_id", "")
        if not session_id:
            _die(f"Task '{slug}' has no session_id — cannot resume.")

        cwd   = task.get("cwd", os.getcwd())
        model = task.get("model", cfg.default_model)

        print(f"  Session not running — resuming {bold(slug)}…")
        if not tmux.resume_in_session(slug, cwd, session_id, model=model):
            _die("Failed to create tmux session.")

        # Restore extra windows from the last snapshot
        saved_windows = vault.get_windows(slug)
        if saved_windows:
            main_idx = min(w.get("idx", 0) for w in saved_windows)
            extra = [w for w in saved_windows if w.get("idx", 0) != main_idx]
            if extra:
                tmux.restore_windows(slug, saved_windows, session_id, model=model)
                print(f"  Restored windows: {', '.join(w['name'] for w in extra)}")

        vault.update_task(slug, status="starting")
        state.upsert(slug, status="starting")

    tmux.attach(slug)


def cmd_resume(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Recreate a tmux session and resume the Claude session."""
    slug = args.slug
    task = vault.get_task(slug)
    if not task:
        _die(f"Task '{slug}' not found in vault.")

    session_id = task.get("session_id", "")
    if not session_id:
        _die(f"Task '{slug}' has no session_id. Cannot resume.")

    cwd = task.get("cwd", os.getcwd())

    if tmux.session_exists(slug):
        # Session exists — check if claude is actually running in it
        pane = tmux.capture_pane(slug, lines=6)
        claude_running = any(x in pane for x in ["🤖", "Sonnet", "Haiku", "Opus", "claude "])
        if claude_running:
            print(f"{green('✓')} Claude is running — attaching to {bold(tmux.session_name(slug))}")
        else:
            model = getattr(args, "model", None) or task.get("model", "")
            resume_cmd = "claude"
            if model:
                resume_cmd += f" --model {model}"
            resume_cmd += f" --resume {session_id}"
            print(f"  Session exists but Claude is not running — sending resume command…")
            tmux.send_keys(slug, resume_cmd)
            vault.update_task(slug, status="starting")
            state.upsert(slug, status="starting")
        if not args.no_attach:
            tmux.attach(slug)
        return

    model = getattr(args, "model", None) or task.get("model", "")

    if not tmux.resume_in_session(slug, cwd, session_id, model=model):
        _die("Failed to create tmux session.")

    vault.update_task(slug, status="starting")
    state.upsert(slug, status="starting")

    # Restore extra windows from the last snapshot
    saved_windows = vault.get_windows(slug)
    if saved_windows:
        main_idx = min(w.get("idx", 0) for w in saved_windows)
        extra = [w for w in saved_windows if w.get("idx", 0) != main_idx]
        if extra:
            tmux.restore_windows(slug, saved_windows, session_id, model=model)
            names = [w["name"] for w in extra]
            print(f"{green('✓')} Restored {len(extra)} extra window(s): {', '.join(names)}")

    print(f"{green('✓')} Resuming task {bold(slug)}")
    if saved_windows:
        print(f"  Windows: {', '.join(w['name'] for w in saved_windows)}")
    if not args.no_attach:
        tmux.attach(slug)


def cmd_snapshot(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Save the current window layout for a task (auto-saved on session end)."""
    slug = args.slug
    if not tmux.session_exists(slug):
        _die(f"No live session for '{slug}'. Window state is auto-saved when Claude exits.")
    windows = tmux.snapshot_windows(slug)
    if not windows:
        _die("No windows found in session.")
    vault.save_windows(slug, windows)
    names = [f"{w['idx']}:{w['name']}" for w in windows]
    print(f"{green('✓')} Saved {len(windows)} window(s): {', '.join(names)}")


def _has_summary(vault: VaultManager, slug: str) -> bool:
    task = vault.get_task(slug)
    return bool(task) and "## Session Summary" in task.get("body", "")


def cmd_done(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Mark a task as done: distill, archive, kill session."""
    slug = args.slug
    task = vault.get_task(slug)
    if not task:
        _die(f"Task '{slug}' not found.")

    session_id = task.get("session_id", "")
    distill = cfg.distill if not args.no_distill else "off"

    # Distillation: open summary window before killing.
    # Skipped when the task note already contains a session summary, so a
    # second `loom done <slug>` proceeds straight to archiving.
    if distill != "off" and not _has_summary(vault, slug) \
            and tmux.session_exists(slug) and session_id:
        if distill == "auto" or _confirm("Open distillation window?"):
            print(f"Opening distillation window in {tmux.session_name(slug)}…")
            tmux.open_distill_window(slug, session_id, cwd=task.get("cwd", ""))
            if args.finish:
                # Wait for the summary to land in the task note, then archive
                import time as _time
                print("  Waiting for the summary to be written to the task note…")
                deadline = _time.time() + 300
                while _time.time() < deadline:
                    _time.sleep(5)
                    if _has_summary(vault, slug):
                        print(f"  {green('✓')} Summary saved to task note.")
                        break
                else:
                    print(yellow("  Timed out waiting for the summary — not archiving."))
                    print(f"  Review the 'distill' window, then re-run: {bold(f'loom done {slug}')}")
                    return
            else:
                print("  Switch to the 'distill' window to review the summary.")
                print(f"  Once the summary is saved, re-run {bold(f'loom done {slug}')} to archive")
                print(f"  (or use {bold(f'loom done {slug} --finish')} to wait and archive automatically).")
                return  # Let user review distillation first

    if not args.yes and not _confirm(f"Mark '{slug}' as done and archive it?"):
        return

    # Kill session
    if tmux.session_exists(slug):
        tmux.kill_session(slug)
        print(f"  Killed session {tmux.session_name(slug)}")

    vault.update_task(slug, status="done")
    vault.archive_task(slug)
    # Keep in state as done (visible with loom ls --all) instead of removing
    state.upsert(slug, status="done")

    print(f"{green('✓')} Task {bold(slug)} archived  (visible with: loom ls --all)")


def cmd_link(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Link a document to a task note."""
    slug = args.slug
    doc  = args.doc

    # Normalise: if path is absolute and inside vault, make it relative
    vault_str = str(vault.vault)
    if doc.startswith(vault_str):
        doc = doc[len(vault_str):].lstrip("/")

    if not vault.link_doc(slug, doc):
        _die(f"Task '{slug}' not found.")
    print(f"{green('✓')} Linked {dim(doc)} → {bold(slug)}")


def cmd_web(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Start the web UI server."""
    loom_dir = find_loom_dir()
    server_script = loom_dir / "web" / "server.py"
    if not server_script.exists():
        _die(f"Web server not found at {server_script}")

    port = args.port or cfg.web_port
    bind = args.bind or cfg.web_bind

    print(f"Starting loom web UI on {bold(f'http://{bind}:{port}')}")
    if cfg.web_token:
        print(f"  Token auth enabled — append {bold(f'?token=<your-token>')} to the URL")
    print("  Press Ctrl+C to stop\n")

    try:
        subprocess.run([sys.executable, str(server_script), "--port", str(port), "--bind", bind])
    except KeyboardInterrupt:
        print("\nStopped.")


def cmd_tunnel(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Manage the reverse SSH tunnel to the loom gateway."""
    action = args.action

    systemd_dir = Path.home() / ".config" / "systemd" / "user"
    loom_dir    = find_loom_dir()
    web_svc     = systemd_dir / "loom-web.service"
    tun_svc     = systemd_dir / "loom-tunnel.service"

    def systemctl(*cmd):
        return subprocess.run(["systemctl", "--user", *cmd], capture_output=True)

    if action == "status":
        for svc in ("loom-web", "loom-tunnel"):
            r = systemctl("is-active", svc)
            active = r.stdout.decode().strip()
            dot = green("●") if active == "active" else red("○")
            print(f"  {dot} {svc}: {active}")
        gw = cfg.get("LOOM_GATEWAY_HOST")
        if gw:
            port = cfg.get("LOOM_GATEWAY_PORT")
            user = cfg.get("LOOM_GATEWAY_USER")
            print(f"\n  Gateway : {user}@{gw}  (remote port {port})")
        else:
            print(f"\n  {dim('No gateway configured — set LOOM_GATEWAY_HOST in config')}")
        return

    if action == "enable":
        gw = cfg.get("LOOM_GATEWAY_HOST")
        if not gw:
            _die("Set LOOM_GATEWAY_HOST in ~/.config/loom/config first.")

        if not shutil.which("autossh"):
            _die("autossh not installed. Run: sudo dnf install autossh  (or apt install autossh)")

        systemd_dir.mkdir(parents=True, exist_ok=True)

        # Install service files
        for src, dst in [
            (loom_dir / "systemd" / "loom-web.service",    web_svc),
            (loom_dir / "systemd" / "loom-tunnel.service", tun_svc),
        ]:
            if not src.exists():
                _die(f"Service file not found: {src}")
            import shutil as _shutil
            _shutil.copy(src, dst)
            print(f"  Installed {dst.name}")

        systemctl("daemon-reload")
        for svc in ("loom-web", "loom-tunnel"):
            systemctl("enable", "--now", svc)
            r = systemctl("is-active", svc)
            status = r.stdout.decode().strip()
            if status == "active":
                print(f"  {green('✓')} {svc} enabled and running")
            else:
                print(f"  {yellow('⚠')} {svc} enabled but status: {status}")
                print(f"    Check: journalctl --user -u {svc} -n 20")

        port = cfg.get("LOOM_GATEWAY_PORT")
        user = cfg.get("LOOM_GATEWAY_USER")
        print(f"\n  {green('✓')} Tunnel: {user}@{gw}  remote port {port} → localhost:7799")
        print(f"  Gateway URL: https://{gw}/m1/  (or whichever path you configured)")

    elif action == "disable":
        for svc in ("loom-tunnel", "loom-web"):
            systemctl("disable", "--now", svc)
            print(f"  Disabled {svc}")

    elif action == "restart":
        for svc in ("loom-web", "loom-tunnel"):
            systemctl("restart", svc)
            r = systemctl("is-active", svc)
            print(f"  {svc}: {r.stdout.decode().strip()}")

    elif action == "logs":
        svc = args.service or "loom-tunnel"
        subprocess.run(["journalctl", "--user", "-u", svc, "-n", "50", "--no-pager"])


def cmd_sync(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Git-sync the vault (add, commit, pull --rebase, push)."""
    if getattr(args, "enable_timer", False):
        return _sync_enable_timer()

    v = vault.vault
    if not (v / ".git").exists():
        _die(f"Vault at {v} is not a git repo. Run: git init {v}")

    def git(*cmd):
        r = subprocess.run(["git", "-C", str(v), *cmd], capture_output=False)
        return r.returncode == 0

    vault.rebuild_dashboard()
    git("add", "-A")

    # Only commit if there's something to commit
    diff = subprocess.run(["git", "-C", str(v), "diff", "--cached", "--quiet"])
    committed = False
    if diff.returncode != 0:
        git("commit", "-m", f"loom: auto-sync {_now_ts()}")
        committed = True

    # No remote configured → local commit is all we can (and should) do
    remotes = subprocess.run(
        ["git", "-C", str(v), "remote"], capture_output=True, text=True
    ).stdout.split()
    if not remotes:
        what = "committed locally" if committed else "nothing to commit"
        print(f"{green('✓')} Vault {what} — no remote configured, skipping pull/push.")
        print(f"  To sync across machines: git -C {v} remote add origin <url>")
        return

    if not git("pull", "--rebase"):
        print(yellow("Warning: pull --rebase failed. Resolve manually."))

    git("push")
    print(f"{green('✓')} Vault synced.")


def _sync_enable_timer():
    """Install and enable the systemd user timer for periodic vault sync."""
    loom_dir    = find_loom_dir()
    systemd_dir = Path.home() / ".config" / "systemd" / "user"
    systemd_dir.mkdir(parents=True, exist_ok=True)
    for unit in ("loom-sync.service", "loom-sync.timer"):
        src = loom_dir / "systemd" / unit
        if not src.exists():
            _die(f"Unit file not found: {src}")
        shutil.copy(src, systemd_dir / unit)
        print(f"  Installed {unit}")
    subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)
    subprocess.run(["systemctl", "--user", "enable", "--now", "loom-sync.timer"],
                   capture_output=True)
    r = subprocess.run(["systemctl", "--user", "is-active", "loom-sync.timer"],
                       capture_output=True, text=True)
    status = r.stdout.strip()
    dot = green("✓") if status == "active" else yellow("⚠")
    print(f"{dot} loom-sync.timer: {status}  (vault syncs every 30 min)")


def _now_ts():
    from datetime import datetime
    return datetime.now().strftime("%Y-%m-%d %H:%M")


def cmd_rebuild(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Rebuild tasks.json cache from vault frontmatter."""
    state.rebuild_from_vault(vault)
    vault.rebuild_dashboard()
    count = len(state.list_all())
    print(f"{green('✓')} Rebuilt cache — {count} task(s).")


def cmd_adr(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Create a new ADR in the vault."""
    if not vault.is_initialized():
        _die("Vault not initialized. Run: loom init")
    title = " ".join(args.title)
    path = vault.create_adr(title)
    print(f"{green('✓')} Created {path.name}")
    print(f"  Edit: {path}")


def cmd_preview(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Show a live pane preview for a task."""
    slug = args.slug
    if not tmux.session_exists(slug):
        _die(f"No live session for '{slug}'.")
    print(bold(f"── {slug} ── window 0 pane 0 ──"))
    print(tmux.capture_pane(slug, lines=args.lines))


def cmd_send(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Send text input to a task's main pane."""
    slug = args.slug
    text = " ".join(args.text)
    if not tmux.session_exists(slug):
        _die(f"No live session for '{slug}'.")
    if not args.yes and not _confirm(f"Send to {slug}: {repr(text)}"):
        return
    tmux.send_keys(slug, text, enter=not args.no_enter)
    print(f"{green('✓')} Sent.")


def cmd_search(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Case-insensitive search across all vault markdown files."""
    if not vault.is_initialized():
        _die("Vault not initialized. Run: loom init")
    term = " ".join(args.term).lower()
    hits = 0
    for p in sorted(vault.vault.rglob("*.md")):
        if ".git" in p.parts:
            continue
        rel = p.relative_to(vault.vault)
        shown_header = False
        if term in str(rel).lower():
            print(bold(str(rel)) + dim("  (filename match)"))
            shown_header = True
            hits += 1
        try:
            lines = p.read_text().splitlines()
        except (OSError, UnicodeDecodeError):
            continue
        for n, line in enumerate(lines, 1):
            if term in line.lower():
                if not shown_header:
                    print(bold(str(rel)))
                    shown_header = True
                snippet = line.strip()
                if len(snippet) > 120:
                    snippet = snippet[:119] + "…"
                print(f"  {dim(f'{n}:')} {snippet}")
                hits += 1
        if shown_header:
            print()
    if not hits:
        print(dim(f"No matches for '{' '.join(args.term)}'."))
    else:
        print(dim(f"{hits} match(es)."))


def cmd_note(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Append a log entry to a task note from the CLI."""
    slug = args.slug
    text = " ".join(args.text)
    if not vault.get_task(slug):
        _die(f"Task '{slug}' not found.")
    if not vault.append_log(slug, text):
        _die(f"Could not write to task note for '{slug}' (archived tasks are read-only via note).")
    state.upsert(slug)
    print(f"{green('✓')} Logged to {bold(slug)}: {dim(text[:80])}")


def cmd_doctor(args, cfg: Config, vault: VaultManager, state: StateManager, tmux: TmuxManager, notify: NotifyManager):
    """Check the health of the loom installation."""
    import json as _json

    def ok(msg):   print(f"  {green('✓')} {msg}")
    def bad(msg):  print(f"  {red('✗')} {msg}")
    def meh(msg):  print(f"  {yellow('⚠')} {msg}")

    print(bold("loom doctor"))

    # Binaries
    for cmd_name, required in [("tmux", True), ("git", True), ("claude", True),
                               ("fzf", False), ("notify-send", False)]:
        path = shutil.which(cmd_name)
        if path:
            ok(f"{cmd_name} ({path})")
        elif required:
            bad(f"{cmd_name} not found — required")
        else:
            extra = " (popup uses numbered fallback)" if cmd_name == "fzf" else ""
            meh(f"{cmd_name} not found — optional{extra}")

    # Config + vault
    config_file = Path.home() / ".config" / "loom" / "config"
    ok(f"config: {config_file}") if config_file.exists() else meh(f"no config file at {config_file} (using defaults)")
    if vault.is_initialized():
        ok(f"vault initialized: {vault.vault}")
        if (vault.vault / ".git").exists():
            remotes = subprocess.run(["git", "-C", str(vault.vault), "remote"],
                                     capture_output=True, text=True).stdout.split()
            ok(f"vault git remote: {', '.join(remotes)}") if remotes else meh("vault has no git remote — loom sync stays local")
        else:
            meh("vault is not a git repo — loom sync unavailable")
    else:
        bad(f"vault not initialized at {vault.vault} — run: loom init")

    # Hooks in ~/.claude/settings.json
    settings = Path.home() / ".claude" / "settings.json"
    hook_events = ["SessionStart", "SessionEnd", "Stop", "UserPromptSubmit", "PreCompact", "Notification"]
    try:
        conf = _json.loads(settings.read_text())
        installed = []
        for ev in hook_events:
            cmds = _json.dumps(conf.get("hooks", {}).get(ev, []))
            if "loom" in cmds:
                installed.append(ev)
        missing = [e for e in hook_events if e not in installed]
        ok(f"hooks installed: {', '.join(installed)}") if not missing else bad(f"hooks missing: {', '.join(missing)} — re-run install.sh")
    except (OSError, ValueError):
        bad(f"cannot read {settings} — re-run install.sh")

    # Skills symlinks
    for skill in ("recall", "loom-status"):
        link = Path.home() / ".claude" / "skills" / skill
        ok(f"skill linked: {skill}") if link.is_symlink() or link.exists() else meh(f"skill not linked: {skill} — re-run install.sh")

    # Web security posture
    if not cfg.web_token and cfg.get("LOOM_WEB_BIND") in ("0.0.0.0", "::"):
        meh("web UI binds 0.0.0.0 with NO token — set LOOM_WEB_TOKEN")
    else:
        ok(f"web UI: bind {cfg.web_bind}, token {'set' if cfg.web_token else 'not needed (localhost)'}")

    # Consistency: tasks vs tmux sessions
    live = {s["slug"] for s in tmux.list_sessions()}
    tasks = {t["slug"]: t for t in vault.list_tasks()}
    orphans = live - set(tasks)
    deads   = [s for s, t in tasks.items()
               if s not in live and t.get("status") in ("working", "waiting", "starting")
               and t.get("unmanaged") not in ("true", True)]
    ok("no orphan loom-* tmux sessions") if not orphans else meh(f"tmux sessions without task notes: {', '.join(sorted(orphans))}")
    ok("no dead tasks stuck in live status") if not deads else meh(f"tasks with dead sessions: {', '.join(sorted(deads))} (loom resume or loom done)")

    # Sync timer
    r = subprocess.run(["systemctl", "--user", "is-active", "loom-sync.timer"],
                       capture_output=True, text=True)
    if r.stdout.strip() == "active":
        ok("auto-sync timer active")
    else:
        meh("auto-sync timer not enabled — loom sync --enable-timer")


# ---------------------------------------------------------------------------
# Argument parser
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="loom",
        description="tmux-based Claude Code workbench",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Examples:\n"
            "  loom new auth-refactor --dir ~/work/myapp\n"
            "  loom ls\n"
            "  loom go auth-refactor\n"
            "  loom web\n"
            "  loom sync\n"
        ),
    )
    sub = p.add_subparsers(dest="command", metavar="<command>")

    # init
    p_init = sub.add_parser("init", help="Initialize the vault")
    p_init.add_argument("--no-git", action="store_true", help="Skip git init")

    # new
    p_new = sub.add_parser("new", help="Create a new task")
    p_new.add_argument("slug", help="Task name (will be slugified)")
    p_new.add_argument("--dir", "-d", help="Working directory (default: cwd)")
    p_new.add_argument("--goal", "-g", help="One-line goal description")
    p_new.add_argument("--model", "-m", help="Claude model (skips interactive picker)")

    # ls
    p_ls = sub.add_parser("ls", help="List active tasks")
    p_ls.add_argument("--plain", action="store_true", help="Plain output for scripting/fzf")
    p_ls.add_argument("--all", "-a", action="store_true", help="Include done/archived tasks")

    # go
    p_go = sub.add_parser("go", help="Attach to a task session")
    p_go.add_argument("slug", help="Task name")

    # resume
    p_resume = sub.add_parser("resume", help="Resume a task session")
    p_resume.add_argument("slug", help="Task name")
    p_resume.add_argument("--no-attach", action="store_true", help="Don't attach after creating session")
    p_resume.add_argument("--model", "-m", help="Override model for this resume")

    # done
    p_done = sub.add_parser("done", help="Mark a task as done and archive it")
    p_done.add_argument("slug", help="Task name")
    p_done.add_argument("--no-distill", action="store_true", help="Skip distillation step")
    p_done.add_argument("--finish", action="store_true",
                        help="Wait for the distill summary, then archive automatically")
    p_done.add_argument("-y", "--yes", action="store_true", help="Skip confirmation")

    # web
    p_web = sub.add_parser("web", help="Start the web UI")
    p_web.add_argument("--port", type=int, help="Port (default from config)")
    p_web.add_argument("--bind", help="Bind address (default from config)")

    # sync
    p_sync = sub.add_parser("sync", help="Git-sync the vault")
    p_sync.add_argument("--enable-timer", action="store_true",
                        help="Install + enable a systemd user timer (sync every 30 min)")

    # rebuild
    sub.add_parser("rebuild", help="Rebuild tasks.json from vault")

    # search
    p_search = sub.add_parser("search", help="Search the vault (case-insensitive)")
    p_search.add_argument("term", nargs="+", help="Search term")

    # note
    p_note = sub.add_parser("note", help="Append a log entry to a task note")
    p_note.add_argument("slug", help="Task name")
    p_note.add_argument("text", nargs="+", help="Log text")

    # doctor
    sub.add_parser("doctor", help="Check the health of the loom installation")

    # adr
    p_adr = sub.add_parser("adr", help="Create a new ADR")
    p_adr.add_argument("title", nargs="+", help="ADR title")

    # preview
    p_prev = sub.add_parser("preview", help="Show pane preview for a task")
    p_prev.add_argument("slug", help="Task name")
    p_prev.add_argument("--lines", type=int, default=25, help="Lines to show")

    # send
    p_send = sub.add_parser("send", help="Send text to a task's main pane")
    p_send.add_argument("slug", help="Task name")
    p_send.add_argument("text", nargs="+", help="Text to send")
    p_send.add_argument("--no-enter", action="store_true", help="Don't append Enter")
    p_send.add_argument("-y", "--yes", action="store_true", help="Skip confirmation")

    # popup
    sub.add_parser("popup", help="fzf session picker in a tmux popup (bind to a key!)")

    # link
    p_link = sub.add_parser("link", help="Link a document to a task note")
    p_link.add_argument("slug", help="Task name")
    p_link.add_argument("doc", help="Path to document (absolute or vault-relative)")

    # snapshot
    p_snap = sub.add_parser("snapshot", help="Save current window layout (auto on session exit)")
    p_snap.add_argument("slug", help="Task name")

    # tunnel
    p_tun = sub.add_parser("tunnel", help="Manage reverse SSH tunnel to the gateway")
    p_tun.add_argument("action", choices=["enable", "disable", "restart", "status", "logs"],
                       help="enable=install+start services, disable=stop, logs=show journal")
    p_tun.add_argument("--service", help="Which service for 'logs' (loom-web or loom-tunnel)")

    return p


_COMMANDS = {
    "init":    cmd_init,
    "new":     cmd_new,
    "ls":      cmd_ls,
    "go":      cmd_go,
    "resume":  cmd_resume,
    "done":    cmd_done,
    "web":     cmd_web,
    "sync":    cmd_sync,
    "rebuild": cmd_rebuild,
    "adr":     cmd_adr,
    "preview": cmd_preview,
    "send":    cmd_send,
    "popup":   cmd_popup,
    "link":     cmd_link,
    "snapshot": cmd_snapshot,
    "tunnel":   cmd_tunnel,
    "search":   cmd_search,
    "note":     cmd_note,
    "doctor":   cmd_doctor,
}


def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    cfg, vault, state, tmux, notify = load_managers()

    fn = _COMMANDS.get(args.command)
    if fn is None:
        _die(f"Unknown command: {args.command}")

    try:
        fn(args, cfg, vault, state, tmux, notify)
    except KeyboardInterrupt:
        print()


if __name__ == "__main__":
    main()
